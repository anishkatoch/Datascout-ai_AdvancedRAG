# ── LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# OpenAI (paid fallback — leave blank if not using)
OPENAI_API_KEY=sk-proj-...

# ── Embeddings ─────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_...

# ── Database (Supabase Postgres) ───────────────────────────────
DB_HOST=db.<your-project>.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_NAME=postgres

# ── Supabase Auth ──────────────────────────────────────────────
# Project URL and keys from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Auth / JWT ─────────────────────────────────────────────────
# Used to sign guest tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-use-a-long-random-string

# ── Neo4j (Advanced Mode — Graph DB) ──────────────────────────
# Free AuraDB: https://neo4j.com/cloud/aura-free/
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
