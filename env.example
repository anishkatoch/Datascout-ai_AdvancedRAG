# ── OpenAI ────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Supabase Database ──────────────────────────────────────────
# Get all values from: Supabase dashboard → Project Settings → Database
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Supabase API ───────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=

# ── Embeddings ────────────────────────────────────────────────
# Change EMBEDDING_PROVIDER to switch priority — no code change needed
#   bge    → uses HUGGINGFACE_MODEL_URL + HUGGINGFACE_API_KEY (no local download)
#   openai → uses OPENAI_API_KEY

# If the chosen provider fails, the other is used automatically as fallback.
EMBEDDING_PROVIDER=bge

# HuggingFace Inference API — model accessed via URL + token, nothing downloaded locally
# Get token from: https://huggingface.co/settings/tokens

HUGGINGFACE_API_KEY=
# Model ID — library builds the API URL internally using this + the key above
HUGGINGFACE_MODEL_ID=BAAI/bge-large-en-v1.5

# Dimension MUST match the provider:
#   bge    → 1024
#   openai → 1536
# If you switch provider, update this value and run: alembic revision --autogenerate + alembic upgrade head
EMBEDDING_DIM=1024

# ── Retrieval (MMR) ───────────────────────────────────────────
# RETRIEVAL_K       — chunks returned to the LLM (more = richer context, slower)
# RETRIEVAL_FETCH_K — candidate pool MMR selects from (must be >= RETRIEVAL_K)
# RETRIEVAL_LAMBDA  — 1.0 = pure similarity, 0.0 = pure diversity, 0.7 = recommended balance
RETRIEVAL_K=3
RETRIEVAL_FETCH_K=10
RETRIEVAL_LAMBDA=0.7

# ── Ingestion limits (change anytime — no code changes needed) ─
MAX_FILE_SIZE_MB=15
MAX_FILES_PER_SESSION=3
